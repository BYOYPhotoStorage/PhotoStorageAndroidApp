<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/share_link_title"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="8dp"
        android:text="@string/share_link_body"
        android:textSize="14sp" />

    <RadioGroup
        android:id="@+id/ttl_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="16dp">

        <RadioButton
            android:id="@+id/ttl_1h"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="@string/share_ttl_1h" />

        <RadioButton
            android:id="@+id/ttl_24h"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/share_ttl_24h" />

        <RadioButton
            android:id="@+id/ttl_7d"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/share_ttl_7d" />
    </RadioGroup>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="horizontal"
        android:paddingTop="16dp">

        <Button
            android:id="@+id/cancel"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/share_link_cancel" />

        <Button
            android:id="@+id/create"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/share_link_create" />
    </LinearLayout>
</LinearLayout>
